# Telegram (required)
TG_BOT_TOKEN=
TG_CHAT_ID=

# LLM provider (optional, anthropic|openai)
LLM_PROVIDER=anthropic

# Anthropic (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4.1-mini

# Runtime
DB_PATH=data/alpha.db
LOG_LEVEL=INFO
# LOG_FILE=logs/alpha-monitor.log

# Polling intervals (seconds)
ANNOUNCEMENT_POLL_INTERVAL=30
AGGREGATION_POLL_INTERVAL=15
MONITOR_POLL_INTERVAL=120

# API behavior
ANNOUNCEMENT_FETCH_LIMIT=20
REQUEST_TIMEOUT_SECONDS=15

# Twitter monitoring (no official API key)
TWITTER_ENABLED=false
TWITTER_ACCOUNTS=cz_binance
TWITTER_POLL_INTERVAL=45
TWITTER_FETCH_LIMIT=8
TWITTER_INCLUDE_REPLIES=false
TWITTER_INCLUDE_RETWEETS=false
TWITTER_MIN_CONFIDENCE=0.6

# Twitter auth for twscrape (required when TWITTER_ENABLED=true)
# Prefer file-based multiple accounts:
TWITTER_AUTH_FILE=.twitter_accounts.json
# Or single account fallback:
# TWITTER_LOGIN_USERNAME=
# TWITTER_LOGIN_PASSWORD=
# TWITTER_LOGIN_EMAIL=
# TWITTER_LOGIN_EMAIL_PASSWORD=

# Send startup Telegram message on launch
STARTUP_MESSAGE=true

# Trading (optional, powered by ccxt)
TRADING_ENABLED=false
TRADING_DRY_RUN=true
TRADING_EXCHANGES=binance,okx
TRADING_DEFAULT_QUOTE=USDT
TRADING_MAX_ORDER_USDT=50
TRADING_MAX_SLIPPAGE_BPS=80
TRADING_AUTO_BUY_ENABLED=false
TRADING_AUTO_BUY_TIERS=S,A
TRADING_AUTO_BUY_USDT=20
# Optional allow/block controls, comma-separated symbols
# TRADING_ALLOWED_SYMBOLS=BTC,ETH,SOL
# TRADING_BLOCKED_SYMBOLS=PEPE

# Exchange credentials (required when TRADING_ENABLED=true and TRADING_DRY_RUN=false)
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
# OKX_API_KEY=
# OKX_API_SECRET=
# OKX_API_PASSWORD=
